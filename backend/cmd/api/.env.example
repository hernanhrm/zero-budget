DATABASE_URL=postgres://zero_budget:zero_budget@localhost:5432/zero_budget?sslmode=disable

SERVICE_PORT=8080
SERVICE_NAME=zero-budget-api

DOCS_PATH=docs

# Calls to the identity service (permission checks, etc.)
IDENTITY_URL=http://localhost:3000
INTERNAL_API_KEY=

RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# --- Cloudflare Workers + Containers (production)
# From backend/cmd/api, set Worker secrets so they are injected into the Go container:
#   npx wrangler secret put DATABASE_URL
#   npx wrangler secret put IDENTITY_URL
#   npx wrangler secret put INTERNAL_API_KEY
#   npx wrangler secret put RESEND_API_KEY
#   npx wrangler secret put RESEND_FROM_ADDRESS
# Optional overrides (plain vars in wrangler.jsonc or secrets):
#   SERVICE_PORT (default 8080 in worker), SERVICE_NAME, DOCS_PATH
#   CONFIG_ENV_PATH, CONFIG_ENV_FILENAME
# Deploy: npm run deploy
