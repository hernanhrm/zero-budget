{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "../Dockerfile.api"
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "environment": [
      {
        "variable": "DOCS_PATH",
        "value": "apps/api/docs"
      }
    ]
  }
}
