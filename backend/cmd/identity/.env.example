DATABASE_URL=postgres://zero_budget:zero_budget@localhost:5432/zero_budget?sslmode=disable

# Required in production. For Cloudflare: wrangler secret put BETTER_AUTH_SECRET (openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# Public URL of this service (local or https://…workers.dev for deployed Worker)
BETTER_AUTH_URL=http://localhost:8081

PORT=8081

GO_API_URL=http://localhost:8080
INTERNAL_API_KEY=

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
